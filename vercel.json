{
  "functions": {
    "api/*.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/web/admin/index.html" },
    { "source": "/share/(.*)", "destination": "/web/share/index.html" },
    { "source": "/(.*)", "destination": "/web/$1" }
  ]
}
